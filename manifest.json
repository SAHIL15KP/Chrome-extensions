{
    "manifest_version":3,
    "version":"1.1.1",
    "name":"Leads Tracker",
    "description":"Save links from the current tab or from manual input.",
    "action":{
        "default_title":"Leads Tracker",
        "default_popup":"index.html",
        "default_icon":{
            "16":"icon-16.png",
            "32":"icon-32.png"
        }
    },
    "icons":{
        "16":"icon-16.png",
        "48":"icon-48.png",
        "128":"icon-128.png"
    },
    "permissions":[
        "tabs"
    ]

}
